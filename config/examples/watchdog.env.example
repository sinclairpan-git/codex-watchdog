# Watchdog（B 机）
WATCHDOG_API_TOKEN=replace-with-shared-secret
WATCHDOG_HOST=127.0.0.1
WATCHDOG_PORT=8720
WATCHDOG_A_AGENT_BASE_URL=http://127.0.0.1:8710
WATCHDOG_A_AGENT_TOKEN=replace-with-same-as-A_AGENT_API_TOKEN
WATCHDOG_HTTP_TIMEOUT_S=3
WATCHDOG_DATA_DIR=.data/watchdog
# critical → handoff 成功后是否继续调用 A 侧 resume（默认 false）
WATCHDOG_RECOVER_AUTO_RESUME=false

# 默认仍走 OpenClaw compatibility delivery；切到 Feishu 主控制面时改成 feishu
WATCHDOG_DELIVERY_TRANSPORT=openclaw
# WATCHDOG_DELIVERY_TRANSPORT=feishu

# 启用 Feishu direct delivery + official event ingress 时填写以下变量
# WATCHDOG_FEISHU_EVENT_INGRESS_MODE=long_connection
# WATCHDOG_FEISHU_CALLBACK_INGRESS_MODE=long_connection
# WATCHDOG_FEISHU_APP_ID=cli_xxx
# WATCHDOG_FEISHU_APP_SECRET=replace-with-feishu-app-secret
# WATCHDOG_FEISHU_VERIFICATION_TOKEN=replace-with-feishu-verification-token
# WATCHDOG_FEISHU_RECEIVE_ID=oc_xxx_or_chat_id
# WATCHDOG_FEISHU_RECEIVE_ID_TYPE=chat_id
# WATCHDOG_FEISHU_INTERACTION_WINDOW_SECONDS=900
# 可选：Feishu 控制面 smoke，要求 B 机能从 A 机解析到该 project 的 envelope
# WATCHDOG_SMOKE_FEISHU_CONTROL_PROJECT_ID=demo-project
# WATCHDOG_SMOKE_FEISHU_CONTROL_GOAL_MESSAGE=继续把主链路推进到 release gate
# WATCHDOG_SMOKE_FEISHU_CONTROL_EXPECTED_SESSION_ID=session:demo-project
# WATCHDOG_SMOKE_FEISHU_CONTROL_ACTOR_OPEN_ID=ou_smoke_actor
# WATCHDOG_SMOKE_FEISHU_CONTROL_HTTP_TIMEOUT_S=15

# OpenClaw / 外部模板调用 Watchdog 时复用以下变量
WATCHDOG_BASE_URL=http://127.0.0.1:8720
# 显式 project_id 优先；未传入时模板会回退到该默认值
WATCHDOG_DEFAULT_PROJECT_ID=demo-project
# 示例模板默认操作人（可选，默认 openclaw）
WATCHDOG_OPERATOR=openclaw

# 默认仍走 resident_orchestrator；切到外部模型时改成 openai-compatible
WATCHDOG_BRAIN_PROVIDER_NAME=resident_orchestrator
# WATCHDOG_BRAIN_PROVIDER_NAME=openai-compatible
# WATCHDOG_BRAIN_PROVIDER_BASE_URL=https://api.openai.com/v1
# WATCHDOG_BRAIN_PROVIDER_MODEL=replace-with-model-id
# WATCHDOG_BRAIN_PROVIDER_HTTP_TIMEOUT_S=30
# 推荐：把 API key 存在 macOS Keychain，而不是明文写进 env 文件
# WATCHDOG_BRAIN_PROVIDER_API_KEY_KEYCHAIN_SERVICE=watchdog.brain-provider
# WATCHDOG_BRAIN_PROVIDER_API_KEY_KEYCHAIN_ACCOUNT=default
# 仅在无法使用 Keychain 时，才临时用明文环境变量
# WATCHDOG_BRAIN_PROVIDER_API_KEY=replace-with-openai-compatible-token

# 启用 Memory Hub AI_AutoSDLC preview cursor app-level route（默认 false）
WATCHDOG_MEMORY_PREVIEW_AI_AUTOSDLC_CURSOR_ENABLED=false

# A 机 quick tunnel URL 变化后，回调 B 机 bootstrap webhook 的 notifier
WATCHDOG_BOOTSTRAP_WEBHOOK_BASE_URL=http://127.0.0.1:8740
WATCHDOG_BOOTSTRAP_WEBHOOK_TOKEN=replace-with-bootstrap-token
WATCHDOG_PUBLIC_TUNNEL_LOG_PATH=$HOME/Library/Logs/openclaw-watchdog.public-tunnel.err.log
WATCHDOG_PUBLIC_URL_STATE_FILE=.data/watchdog/public_endpoint_state.json
WATCHDOG_PUBLIC_URL_NOTIFY_INTERVAL_SECONDS=10
WATCHDOG_PUBLIC_URL_SOURCE=a-host-watchdog

# B 机 public OpenClaw webhook URL 变化后，A 机 Watchdog 持久化最新公网入口
# 若未显式设置，则默认落到 WATCHDOG_DATA_DIR/openclaw_webhook_endpoint.json
WATCHDOG_OPENCLAW_WEBHOOK_ENDPOINT_STATE_FILE=.data/watchdog/openclaw_webhook_endpoint.json
